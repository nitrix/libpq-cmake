/* libpq-cmake: CMake-driven replacement for src/include/pg_config.h.
 * Probes live in cmake/ConfigureChecks.cmake. */

#ifndef PG_CONFIG_H
#define PG_CONFIG_H

/* --- Constants always defined --------------------------------------- */
#define BLCKSZ                       @BLCKSZ@
#define XLOG_BLCKSZ                  @XLOG_BLCKSZ@
#define RELSEG_SIZE                  @RELSEG_SIZE@
#define DEF_PGPORT                   @DEF_PGPORT@
#define DEF_PGPORT_STR               @DEF_PGPORT_STR@
#define PG_KRB_SRVNAM                @PG_KRB_SRVNAM@
#define MEMSET_LOOP_LIMIT            @MEMSET_LOOP_LIMIT@
#define PROFILE_PID_DIR              @PROFILE_PID_DIR@
#define CONFIGURE_ARGS               @CONFIGURE_ARGS@
#define PACKAGE_NAME                 @PACKAGE_NAME@
#define PACKAGE_TARNAME              @PACKAGE_TARNAME@
#define PACKAGE_VERSION              @PACKAGE_VERSION@
#define PACKAGE_STRING               @PACKAGE_STRING@
#define PACKAGE_BUGREPORT            @PACKAGE_BUGREPORT@
#define PACKAGE_URL                  @PACKAGE_URL@
#define DLSUFFIX                     @DLSUFFIX@
#define PG_VERSION                   "@PG_VERSION@"
#define PG_MAJORVERSION              "@PG_MAJORVERSION@"
#define PG_MAJORVERSION_NUM          @PG_MAJORVERSION_NUM@
#define PG_MINORVERSION_NUM          @PG_MINORVERSION_NUM@
#define PG_VERSION_NUM               @PG_VERSION_NUM@
#define PG_VERSION_STR               @PG_VERSION_STR@

/* --- Value defines (computed by CMake) ------------------------------ */
#cmakedefine SIZEOF_LONG             @SIZEOF_LONG@
#cmakedefine SIZEOF_OFF_T            @SIZEOF_OFF_T@
#cmakedefine SIZEOF_SIZE_T           @SIZEOF_SIZE_T@
#cmakedefine SIZEOF_VOID_P           @SIZEOF_VOID_P@
#cmakedefine SIZEOF_BOOL             @SIZEOF_BOOL@
#cmakedefine ALIGNOF_SHORT           @ALIGNOF_SHORT@
#cmakedefine ALIGNOF_INT             @ALIGNOF_INT@
#cmakedefine ALIGNOF_LONG            @ALIGNOF_LONG@
#cmakedefine ALIGNOF_LONG_LONG_INT   @ALIGNOF_LONG_LONG_INT@
#cmakedefine ALIGNOF_DOUBLE          @ALIGNOF_DOUBLE@
#cmakedefine ALIGNOF_PG_INT128_TYPE  @ALIGNOF_PG_INT128_TYPE@
#cmakedefine MAXIMUM_ALIGNOF         @MAXIMUM_ALIGNOF@
#cmakedefine PG_INT64_TYPE           @PG_INT64_TYPE@
#cmakedefine PG_INT128_TYPE          @PG_INT128_TYPE@
#cmakedefine INT64_MODIFIER          @INT64_MODIFIER@
#cmakedefine PG_C_PRINTF_ATTRIBUTE   @PG_C_PRINTF_ATTRIBUTE@
#cmakedefine PG_CXX_PRINTF_ATTRIBUTE @PG_CXX_PRINTF_ATTRIBUTE@
#cmakedefine OPENSSL_API_COMPAT      @OPENSSL_API_COMPAT@
#cmakedefine _FILE_OFFSET_BITS       @_FILE_OFFSET_BITS@
#cmakedefine _LARGEFILE_SOURCE       @_LARGEFILE_SOURCE@
#cmakedefine _LARGE_FILES            @_LARGE_FILES@
#cmakedefine STRERROR_R_INT          1

/* PG_USE_STDBOOL: define if <stdbool.h> works */
#cmakedefine PG_USE_STDBOOL          1

/* --- Header presence (HAVE_<HEADER>_H) ------------------------------ */
#cmakedefine HAVE_ATOMIC_H 1
#cmakedefine HAVE_COPYFILE_H 1
#cmakedefine HAVE_CRTDEFS_H 1
#cmakedefine HAVE_EDITLINE_HISTORY_H 1
#cmakedefine HAVE_EDITLINE_READLINE_H 1
#cmakedefine HAVE_EXECINFO_H 1
#cmakedefine HAVE_GETOPT_H 1
#cmakedefine HAVE_GSSAPI_H 1
#cmakedefine HAVE_GSSAPI_GSSAPI_H 1
#cmakedefine HAVE_GSSAPI_EXT_H 1
#cmakedefine HAVE_GSSAPI_GSSAPI_EXT_H 1
#cmakedefine HAVE_HISTORY_H 1
#cmakedefine HAVE_IFADDRS_H 1
#cmakedefine HAVE_INTTYPES_H 1
#cmakedefine HAVE_LANGINFO_H 1
#cmakedefine HAVE_MBARRIER_H 1
#cmakedefine HAVE_MEMORY_H 1
#cmakedefine HAVE_OSSP_UUID_H 1
#cmakedefine HAVE_PAM_PAM_APPL_H 1
#cmakedefine HAVE_READLINE_H 1
#cmakedefine HAVE_READLINE_HISTORY_H 1
#cmakedefine HAVE_READLINE_READLINE_H 1
#cmakedefine HAVE_SECURITY_PAM_APPL_H 1
#cmakedefine HAVE_STDINT_H 1
#cmakedefine HAVE_STDLIB_H 1
#cmakedefine HAVE_STRING_H 1
#cmakedefine HAVE_STRINGS_H 1
#cmakedefine HAVE_SYS_EPOLL_H 1
#cmakedefine HAVE_SYS_EVENT_H 1
#cmakedefine HAVE_SYS_PERSONALITY_H 1
#cmakedefine HAVE_SYS_PRCTL_H 1
#cmakedefine HAVE_SYS_PROCCTL_H 1
#cmakedefine HAVE_SYS_SIGNALFD_H 1
#cmakedefine HAVE_SYS_STAT_H 1
#cmakedefine HAVE_SYS_TYPES_H 1
#cmakedefine HAVE_SYS_UCRED_H 1
#cmakedefine HAVE_TERMIOS_H 1
#cmakedefine HAVE_UCRED_H 1
#cmakedefine HAVE_UNISTD_H 1
#cmakedefine HAVE_UUID_H 1
#cmakedefine HAVE_UUID_UUID_H 1
#define STDC_HEADERS 1

/* --- Function presence (HAVE_<FUNC>) -------------------------------- */
#cmakedefine HAVE_BACKTRACE_SYMBOLS 1
#cmakedefine HAVE_COPYFILE 1
#cmakedefine HAVE_COPY_FILE_RANGE 1
#cmakedefine HAVE_EXPLICIT_BZERO 1
#cmakedefine HAVE_FSEEKO 1
#cmakedefine HAVE_GETIFADDRS 1
#cmakedefine HAVE_GETOPT 1
#cmakedefine HAVE_GETOPT_LONG 1
#cmakedefine HAVE_GETPEEREID 1
#cmakedefine HAVE_GETPEERUCRED 1
#cmakedefine HAVE_HISTORY_TRUNCATE_FILE 1
#cmakedefine HAVE_INET_ATON 1
#cmakedefine HAVE_INET_PTON 1
#cmakedefine HAVE_KQUEUE 1
#cmakedefine HAVE_MBSTOWCS_L 1
#cmakedefine HAVE_MKDTEMP 1
#cmakedefine HAVE_POSIX_FADVISE 1
#cmakedefine HAVE_POSIX_FALLOCATE 1
#cmakedefine HAVE_PPOLL 1
#cmakedefine HAVE_PTHREAD_BARRIER_WAIT 1
#cmakedefine HAVE_PTHREAD_IS_THREADED_NP 1
#cmakedefine HAVE_RL_COMPLETION_MATCHES 1
#cmakedefine HAVE_RL_FILENAME_COMPLETION_FUNCTION 1
#cmakedefine HAVE_RL_RESET_SCREEN_SIZE 1
#cmakedefine HAVE_RL_VARIABLE_BIND 1
#cmakedefine HAVE_SETPROCTITLE 1
#cmakedefine HAVE_SETPROCTITLE_FAST 1
#cmakedefine HAVE_STRERROR_R 1
#cmakedefine HAVE_STRLCAT 1
#cmakedefine HAVE_STRLCPY 1
#cmakedefine HAVE_STRNLEN 1
#cmakedefine HAVE_STRSIGNAL 1
#cmakedefine HAVE_SYNCFS 1
#cmakedefine HAVE_SYNC_FILE_RANGE 1
#cmakedefine HAVE_TIMINGSAFE_BCMP 1
#cmakedefine HAVE_USELOCALE 1
#cmakedefine HAVE_WCSTOMBS_L 1

/* --- HAVE_DECL_* (0 or 1, always defined) --------------------------- */
#cmakedefine01 HAVE_DECL_FDATASYNC
#cmakedefine01 HAVE_DECL_F_FULLFSYNC
#cmakedefine01 HAVE_DECL_MEMSET_S
#cmakedefine01 HAVE_DECL_POSIX_FADVISE
#cmakedefine01 HAVE_DECL_PREADV
#cmakedefine01 HAVE_DECL_PWRITEV
#cmakedefine01 HAVE_DECL_STRCHRNUL
#cmakedefine01 HAVE_DECL_STRLCAT
#cmakedefine01 HAVE_DECL_STRLCPY
#cmakedefine01 HAVE_DECL_STRNLEN
#cmakedefine01 HAVE_DECL_TIMINGSAFE_BCMP

/* LLVM is not used in this client-only build */
#define HAVE_DECL_LLVMCREATEGDBREGISTRATIONLISTENER 0
#define HAVE_DECL_LLVMCREATEPERFJITEVENTLISTENER 0

/* --- Types and structs ---------------------------------------------- */
#cmakedefine HAVE_SOCKLEN_T 1
#cmakedefine HAVE_STRUCT_OPTION 1
#cmakedefine HAVE_STRUCT_SOCKADDR_SA_LEN 1
#cmakedefine HAVE_STRUCT_TM_TM_ZONE 1
#cmakedefine HAVE_INT64 1
#cmakedefine HAVE_INT8 1
