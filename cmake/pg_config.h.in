#cmakedefine HAVE_LONG_LONG_INT_64 1

#cmakedefine HAVE_INT_OPTERR 1
#cmakedefine HAVE_INT_OPTRESET 1
#cmakedefine HAVE_INT_TIMEZONE 1
#cmakedefine HAVE_TYPEOF 1
#cmakedefine HAVE_VISIBILITY_ATTRIBUTE 1
#cmakedefine HAVE_COMPUTED_GOTO 1
#cmakedefine HAVE_I_CONSTRAINT__BUILTIN_CONSTANT_P 1

/* --- Compiler builtins ---------------------------------------------- */
#cmakedefine HAVE__BUILTIN_BSWAP16 1
#cmakedefine HAVE__BUILTIN_BSWAP32 1
#cmakedefine HAVE__BUILTIN_BSWAP64 1
#cmakedefine HAVE__BUILTIN_CLZ 1
#cmakedefine HAVE__BUILTIN_CONSTANT_P 1
#cmakedefine HAVE__BUILTIN_CTZ 1
#cmakedefine HAVE__BUILTIN_FRAME_ADDRESS 1
#cmakedefine HAVE__BUILTIN_OP_OVERFLOW 1
#cmakedefine HAVE__BUILTIN_POPCOUNT 1
#cmakedefine HAVE__BUILTIN_TYPES_COMPATIBLE_P 1
#cmakedefine HAVE__BUILTIN_UNREACHABLE 1
#cmakedefine HAVE__CONFIGTHREADLOCALE 1
#cmakedefine HAVE__CPUID 1
#cmakedefine HAVE__CPUIDEX 1
#cmakedefine HAVE__GET_CPUID 1
#cmakedefine HAVE__GET_CPUID_COUNT 1
#cmakedefine HAVE__STATIC_ASSERT 1
#cmakedefine HAVE_XSAVE_INTRINSICS 1
#cmakedefine HAVE_X86_64_POPCNTQ 1

/* --- Atomics / sync builtins --------------------------------------- */
#cmakedefine HAVE_ATOMICS 1
#cmakedefine HAVE_SPINLOCKS 1
#cmakedefine HAVE_GCC__ATOMIC_INT32_CAS 1
#cmakedefine HAVE_GCC__ATOMIC_INT64_CAS 1
#cmakedefine HAVE_GCC__SYNC_CHAR_TAS 1
#cmakedefine HAVE_GCC__SYNC_INT32_CAS 1
#cmakedefine HAVE_GCC__SYNC_INT32_TAS 1
#cmakedefine HAVE_GCC__SYNC_INT64_CAS 1

/* --- pthreads ------------------------------------------------------- */
#cmakedefine HAVE_PTHREAD 1
#cmakedefine HAVE_PTHREAD_PRIO_INHERIT 1
#cmakedefine PTHREAD_CREATE_JOINABLE @PTHREAD_CREATE_JOINABLE@

/* --- xlocale -------------------------------------------------------- */
#cmakedefine LOCALE_T_IN_XLOCALE 1
#cmakedefine WCSTOMBS_L_IN_XLOCALE 1

/* --- UUID (not used by libpq client, kept for completeness) --------- */
#cmakedefine HAVE_UUID_BSD 1
#cmakedefine HAVE_UUID_E2FS 1
#cmakedefine HAVE_UUID_OSSP 1

/* --- Library presence ----------------------------------------------- */
#cmakedefine HAVE_LIBCRYPTO 1
#cmakedefine HAVE_LIBSSL 1
#cmakedefine HAVE_LIBLDAP 1
#cmakedefine HAVE_LIBPAM 1
#cmakedefine HAVE_LIBREADLINE 1
#cmakedefine HAVE_LIBSELINUX 1
#cmakedefine HAVE_LIBM 1
#cmakedefine HAVE_LIBLZ4 1
#cmakedefine HAVE_LIBWLDAP32 1
#cmakedefine HAVE_LIBXML2 1
#cmakedefine HAVE_LIBXSLT 1
#cmakedefine HAVE_LIBZ 1
#cmakedefine HAVE_LIBZSTD 1

/* --- OpenSSL feature probes ----------------------------------------- */
#cmakedefine HAVE_ASN1_STRING_GET0_DATA 1
#cmakedefine HAVE_BIO_METH_NEW 1
#cmakedefine HAVE_CRYPTO_LOCK 1
#cmakedefine HAVE_HMAC_CTX_FREE 1
#cmakedefine HAVE_HMAC_CTX_NEW 1
#cmakedefine HAVE_OPENSSL_INIT_SSL 1
#cmakedefine HAVE_SSL_CTX_SET_CERT_CB 1
#cmakedefine HAVE_SSL_CTX_SET_NUM_TICKETS 1
#cmakedefine HAVE_X509_GET_SIGNATURE_INFO 1

/* --- Top-level feature toggles -------------------------------------- */
#cmakedefine USE_OPENSSL 1
#cmakedefine USE_LDAP 1
#cmakedefine USE_PAM 1
#cmakedefine USE_BONJOUR 1
#cmakedefine USE_BSD_AUTH 1
#cmakedefine USE_ICU 1
#cmakedefine USE_INJECTION_POINTS 1
#cmakedefine USE_LIBXML 1
#cmakedefine USE_LIBXSLT 1
#cmakedefine USE_LLVM 1
#cmakedefine USE_LZ4 1
#cmakedefine USE_ZSTD 1
#cmakedefine USE_ASSERT_CHECKING 1
#cmakedefine USE_NAMED_POSIX_SEMAPHORES 1
#cmakedefine USE_UNNAMED_POSIX_SEMAPHORES 1
#cmakedefine USE_SYSV_SEMAPHORES 1
#cmakedefine USE_SYSV_SHARED_MEMORY 1
#cmakedefine USE_WIN32_SEMAPHORES 1
#cmakedefine USE_WIN32_SHARED_MEMORY 1
#cmakedefine USE_SYSTEMD 1
#cmakedefine ENABLE_GSS 1
#cmakedefine ENABLE_NLS 1

/* --- CRC32C selection ---------------------------------------------- */
#cmakedefine USE_ARMV8_CRC32C 1
#cmakedefine USE_ARMV8_CRC32C_WITH_RUNTIME_CHECK 1
#cmakedefine USE_LOONGARCH_CRC32C 1
#cmakedefine USE_SLICING_BY_8_CRC32C 1
#cmakedefine USE_SSE42_CRC32C 1
#cmakedefine USE_SSE42_CRC32C_WITH_RUNTIME_CHECK 1
#cmakedefine USE_AVX512_POPCNT_WITH_RUNTIME_CHECK 1

/* --- Endianness ---------------------------------------------------- */
#cmakedefine WORDS_BIGENDIAN 1

/* --- inline / restrict --------------------------------------------- */
#ifndef __cplusplus
/* C99 reserves `inline` and `restrict`; no remapping needed. */
#endif

/* PostgreSQL spells `restrict` as `pg_restrict` and lets configure decide
 * the spelling. With a C99 compiler we can always use the keyword. */
#ifndef pg_restrict
#define pg_restrict restrict
#endif

#endif /* PG_CONFIG_H */
